# Ollama web tools API key (used by the Web tab for web_search / web_fetch)
# Get one at https://ollama.com — web search fails with 401 until this is set.
OLLAMA_WEB_API_KEY=your-api-key-here

# Optional: override the embedding model used for document search (RAG)
# OLLAMA_EMBED_MODEL=nomic-embed-text
